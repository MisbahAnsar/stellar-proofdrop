# Proofdrop environment variables
# Copy to .env.local for local dev, or set in Vercel → Settings → Environment Variables.

# Application (production default is https://proofdrop-stellar.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stellar / Soroban
NEXT_PUBLIC_STELLAR_NETWORK=testnet
# Optional — leave unset to use the network default RPC
# NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed Proofdrop contract ID (required for on-chain flows)
# NEXT_PUBLIC_PROOFDROP_CONTRACT_ID=C...
